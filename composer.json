{
  "name": "training/uow",
  "description": "Micro UnitOfWork from scratch to understand Doctrine",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "ext-pdo": "*",
    "symfony/config": "^8.0",
    "symfony/dependency-injection": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "TrainingUow\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TrainingUow\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^13.0",
    "rector/rector": "^2.3",
    "tomasvotruba/cognitive-complexity": "^1.0"
  }
}
